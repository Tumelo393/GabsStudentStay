<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Received message (left aligned) -->
    <LinearLayout
        android:id="@+id/layoutReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="start"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvReceivedMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Message text"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:background="@drawable/button_rounded"
            android:backgroundTint="@color/grey_extra_light"
            android:padding="12dp"
            android:maxWidth="260dp" />

        <TextView
            android:id="@+id/tvReceivedTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:30 AM"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <!-- Sent message (right aligned) -->
    <LinearLayout
        android:id="@+id/layoutSent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="end"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvSentMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My message"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:background="@drawable/button_rounded"
            android:backgroundTint="@color/primary"
            android:padding="12dp"
            android:maxWidth="260dp" />

        <TextView
            android:id="@+id/tvSentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:31 AM"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp"
            android:layout_gravity="end"
            android:layout_marginEnd="4dp" />

    </LinearLayout>

</LinearLayout>
